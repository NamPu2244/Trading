# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-32-char-string-for-production

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./trading_ai.db

# ─── AI Cloud Providers (stored encrypted in DB per-agent; these are defaults) ─
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Local AI (Ollama) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── Broker / Exchange (stored encrypted in DB per-agent) ──────────────────────
# Example: Binance paper trading
BINANCE_API_KEY=
BINANCE_SECRET=

# ─── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
